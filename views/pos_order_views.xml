<odoo>
    <record id="view_pos_order_form_sunat_direct" model="ir.ui.view">
        <field name="name">pos.order.form.sunat.direct</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="SUNAT Directo">
                    <field name="sunat_state" readonly="1"/>
                    <field name="sunat_document_type" readonly="1"/>
                    <field name="sunat_document_number" readonly="1"/>
                    <field name="sunat_message" readonly="1"/>
                    <field name="sunat_xml" invisible="1"/>
                    <field name="sunat_xml_filename" readonly="1"/>
                    <field name="sunat_xml_file" filename="sunat_xml_filename" readonly="1"/>
                    <field name="sunat_zip_filename" readonly="1"/>
                    <field name="sunat_cdr_filename" readonly="1"/>
                    <field name="sunat_cdr_file" filename="sunat_cdr_filename" readonly="1"/>
                    <field name="sunat_cdr_code" readonly="1"/>
                    <field name="sunat_cdr_description" readonly="1"/>
                    <field name="sunat_summary_filename" readonly="1"/>
                    <field name="sunat_summary_file" filename="sunat_summary_filename" readonly="1"/>
                    <field name="sunat_summary_xml" invisible="1"/>
                    <field name="sunat_summary_id" readonly="1"/>
                </group>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_send_sunat"
                        string="Enviar a SUNAT"
                        type="object"
                        class="btn-primary"
                        invisible="sunat_document_type == 'NV'"/>
            </xpath>
        </field>
    </record>


    <record id="view_pos_order_tree_documento_reporte" model="ir.ui.view">
        <field name="name">pos.order.tree.documento.reporte</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="tipo_documento_reporte"
                        string="Tipo"/>
                <field name="numero_documento_reporte"
                        string="Número Documento"/>

                <field name="sunat_state"
                        string="Estado SUNAT"/>
            </xpath>
        </field>
    </record>

    <record id="view_pos_order_search_documento_reporte" model="ir.ui.view">
        <field name="name">pos.order.search.documento.reporte</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>

                <filter string="Facturas"
                        name="filter_facturas"
                        domain="[('tipo_documento_reporte', '=', 'factura')]"/>
                <filter string="Boletas"
                        name="filter_boletas"
                        domain="[('tipo_documento_reporte', '=', 'boleta')]"/>
                <filter string="Notas de Ventas"
                        name="filter_notas_ventas"
                        domain="[('tipo_documento_reporte', '=', 'nota_venta')]"/>
            </xpath>
        </field>
    </record>
</odoo>