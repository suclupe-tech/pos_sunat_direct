<odoo>

    <record id="ir_cron_send_daily_boletas_rc" model="ir.cron">
        <field name="name">SUNAT - Enviar Resumen Diario Boletas POS</field>
        <field name="model_id" ref="model_sunat_cron_service"/>
        <field name="state">code</field>
        <field name="code">model.cron_send_daily_boletas_rc()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=23, minute=0, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

    <record id="ir_cron_check_pending_tickets" model="ir.cron">
        <field name="name">SUNAT - Consultar Tickets RC POS</field>
        <field name="model_id" ref="model_sunat_cron_service"/>
        <field name="state">code</field>
        <field name="code">model.cron_check_pending_tickets()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

</odoo>