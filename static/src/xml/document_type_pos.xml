<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_sunat_direct.HideInvoiceButton"
        t-inherit="point_of_sale.PaymentScreenButtons"
        t-inherit-mode="extension">

        <xpath expr="//button[contains(@class, 'js_invoice')]" position="replace">
        </xpath>

    </t>

    <t t-name="pos_sunat_direct.PaymentScreenButtons"
        t-inherit="point_of_sale.PaymentScreenMethods"
        t-inherit-mode="extension">

        <xpath expr="//div[contains(@class, 'paymentmethods-container')]" position="before">

            <div class="mb-2 p-2 border rounded bg-light">

                <div class="fw-bold mb-2 text-center fs-5">
                    Tipo de Documento
                </div>

                <div class="d-flex gap-2">

                    <button class="btn flex-fill py-2"
                            t-att-class="sunatState.document_type === '03'
                                ? 'btn-primary'
                                : 'btn-outline-primary'"
                            t-on-click="() => this.setDocumentType('03')">
                        Boleta
                    </button>

                    <button class="btn flex-fill py-2"
                            t-att-class="sunatState.document_type === '01'
                                ? 'btn-success'
                                : 'btn-outline-success'"
                            t-on-click="() => this.setDocumentType('01')">
                        Factura
                    </button>

                    <button class="btn flex-fill py-2"
                            t-att-class="sunatState.document_type === 'NV'
                                ? 'btn-warning'
                                : 'btn-outline-warning'"
                            t-on-click="() => this.setDocumentType('NV')">
                        Nota Venta
                    </button>

                </div>

            </div>

        </xpath>

    </t>

</templates>