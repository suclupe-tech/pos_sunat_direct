<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_sunat_direct.PaymentScreenButtons"
        t-inherit="point_of_sale.PaymentScreenButtons"
        t-inherit-mode="extension">

        <!-- Ocultar botón Recibo/Factura -->
    <xpath expr="//button[contains(@class, 'js_invoice')]" position="replace">
        <!-- vacío = eliminado -->
    </xpath>

        <xpath expr="//div[contains(@class, 'payment-buttons')]" position="inside">

            <div class="mt-2 d-flex gap-2 flex-wrap">
                <button class="btn btn-secondary"
                        t-on-click="() => this.setDocumentType('03')">
                    Boleta
                </button>

                <button class="btn btn-secondary"
                        t-on-click="() => this.setDocumentType('01')">
                    Factura
                </button>

                <button class="btn btn-secondary"
                        t-on-click="() => this.setDocumentType('NV')">
                    Nota de Venta
                </button>
            </div>

        </xpath>

    </t>

</templates>